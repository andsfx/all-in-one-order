# Supabase (dari Supabase Dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Cashi.id Payment Gateway (dari Cashi.id Dashboard > Settings > API)
CASHI_API_KEY=your_cashi_api_key_here
CASHI_WEBHOOK_SECRET=your_cashi_webhook_secret_here

# Demo mode (hanya untuk demo environment, hide di production client)
VITE_IS_DEMO=false
