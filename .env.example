# ============================================
# Client-side (bundled into frontend via Vite)
# ============================================

# Supabase (dari Supabase Dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Demo mode (hanya untuk demo environment, hide di production client)
VITE_IS_DEMO=false

# ============================================
# Server-side / Supabase Edge Functions
# ============================================

# Payment gateway (Cashi.id Dashboard > Settings > API)
CASHI_API_KEY=your_cashi_api_key_here
CASHI_WEBHOOK_SECRET=your_cashi_webhook_secret_here

# CORS allowed origins (comma-separated, e.g. https://yourdomain.com)
ALLOWED_ORIGINS=https://yourdomain.com

# Webhook signature verification secret (HMAC)
BAYAR_WEBHOOK_SECRET=your_bayar_webhook_secret_here

# Maintenance mode token (used by admin to toggle maintenance)
MAINTENANCE_TOKEN=your_maintenance_token_here
